# ============================================================
#  DENTVISION — Plantilla de variables de entorno
#  Copia este archivo como .env.local y ajusta los valores
# ============================================================

# Producción: https://backend-dentvision-project.onrender.com
# Desarrollo local: http://localhost:8080  (puerto del backend Spring Boot)
# NOTA: el backend NO usa prefijo /api — las rutas son directas (ej: /auth/login, /citas)
VITE_API_URL=https://backend-dentvision-project.onrender.com

# false = API real | true = datos mock locales (útil sin backend)
VITE_USE_MOCK_API=false
